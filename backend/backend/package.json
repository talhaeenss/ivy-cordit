{
  "name": "cordit-backend",
  "version": "1.0.0",
  "description": "Cordit - Lightweight Discord-like chat backend with real-time messaging and voice support",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "create-admin": "tsx src/utils/createAdmin.ts"
  },
  "keywords": [
    "chat",
    "discord",
    "voice",
    "livekit",
    "socket.io",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/cordit.git"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.14.2",
    "mongoose": "^8.20.1",
    "pino": "^8.21.0",
    "pino-pretty": "^11.3.0",
    "socket.io": "^4.8.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^25.0.9",
    "@types/socket.io": "^3.0.2",
    "@types/yargs": "^17.0.35",
    "eslint": "^9.0.0",
    "globals": "^16.5.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  }
}
