# Cordit Flutter App - Environment Variables Example
# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin

# Backend API URL
API_BASE_URL=http://localhost:3001

# Socket.IO URL
SOCKET_URL=http://localhost:3001

# LiveKit Server URL
LIVEKIT_URL=ws://localhost:7880

# Not: Bu değişkenleri kullanmak için:
# flutter run --dart-define=API_BASE_URL=http://192.168.1.45:3001 --dart-define=SOCKET_URL=http://192.168.1.45:3001 --dart-define=LIVEKIT_URL=ws://192.168.1.45:7880
